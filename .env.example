# =============================================================================
# Copy to .env on the server:  cp .env.example .env && php artisan key:generate
# Production: set APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-api.domain
# =============================================================================

# --- Application ---
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
# Comma-separated previous APP_KEY values when rotating keys (optional)
APP_PREVIOUS_KEYS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --- Logging ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_DAILY_DAYS=14
# LOG_SLACK_WEBHOOK_URL=
# PAPERTRAIL_URL=
# PAPERTRAIL_PORT=

# --- Database (use mysql/pgsql in production; sqlite is dev-only) ---
DB_CONNECTION=sqlite
# DB_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
# DB_SOCKET=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
# DB_FOREIGN_KEYS=true
# Managed MySQL (RDS, PlanetScale, etc.): path to CA bundle for TLS
# MYSQL_ATTR_SSL_CA=

# --- Cache / queue / sessions (production: prefer redis for cache + queue workers) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# HTTPS production: set true so cookies are only sent over TLS
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=lax
SESSION_CONNECTION=
SESSION_TABLE=sessions

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Production: use redis + `php artisan queue:work` so jobs run (e.g. ProvisionUserCryptoDepositAddressesJob after email verify).
QUEUE_CONNECTION=database
# QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1
# MEMCACHED_PORT=11211

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# REDIS_URL=
# REDIS_DB=0
# REDIS_CACHE_DB=1

# --- Mail (production: use smtp, ses, postmark, etc.) ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_URL=
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_EHLO_DOMAIN=
# POSTMARK_TOKEN=

# --- AWS (S3, SQS, optional mail) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Sanctum (SPA / cookie auth: list your frontend origins, comma-separated) ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_PREFIX=

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Product: virtual cards (BSiCards)
# =============================================================================
BSICARDS_PUBLIC_KEY=
BSICARDS_SECRET_KEY=
BSICARDS_TIMEOUT=30
BSICARDS_BASE_URL=https://cards.bsigroup.tech/api
BSICARDS_MERCHANT_BASE_URL=https://cards.bsigroup.tech/api
BSICARDS_RESELLER_BASE_URL=https://cards.bsigroup.tech/api
BSICARDS_MERCHANT_MASTER_CREATE_PATH=/digitalnewvirtualcard
BSICARDS_MERCHANT_MASTER_GET_ALL_PATH=/getalldigital
BSICARDS_MERCHANT_MASTER_GET_CARD_PATH=/getdigitalcard
BSICARDS_MERCHANT_MASTER_FUND_PATH=/digitalfundcard
BSICARDS_MERCHANT_MASTER_BLOCK_PATH=/blockdigital
BSICARDS_MERCHANT_MASTER_UNBLOCK_PATH=/unblockdigital
BSICARDS_MERCHANT_MASTER_TERMINATE_PATH=/terminatedigital
BSICARDS_MERCHANT_MASTER_TRANSACTIONS_PATH=/digitaltransactions
BSICARDS_MERCHANT_MASTER_CHECK_3DS_PATH=/check3ds
BSICARDS_MERCHANT_MASTER_CHECK_WALLET_PATH=/checkwallet
BSICARDS_MERCHANT_MASTER_APPROVE_3DS_PATH=/approve3ds

VIRTUAL_CARD_CREATION_FEE_USD=3
VIRTUAL_CARD_CREATION_PROCESSING_FEE_NGN=500
VIRTUAL_CARD_USD_TO_NGN_RATE=1500

# =============================================================================
# Product: PalmPay (fiat deposit, bills, payouts — RSA signing)
# =============================================================================
PALMPAY_ENVIRONMENT=sandbox
# Production example: https://open-gw-prod.palmpay-inc.com
PALMPAY_BASE_URL=
PALMPAY_APP_ID=
PALMPAY_API_KEY=
# PEM strings; use \n for newlines in .env
PALMPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PALMPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
PALMPAY_COUNTRY_CODE=NG
PALMPAY_VERSION=V2
# Public URL PalmPay will call (must match your deployed API)
PALMPAY_WEBHOOK_URL=
PALMPAY_VERIFY_WEBHOOK_SIGNATURE=true
PALMPAY_HTTP_TIMEOUT=30
PALMPAY_MIN_DEPOSIT_NGN=100
PALMPAY_USE_FOR_FIAT_DEPOSIT=true
PALMPAY_LEGACY_MANUAL_FIAT_DEPOSIT=false
PALMPAY_USE_FOR_BILL_PAYMENT=true
PALMPAY_USE_FOR_WITHDRAWAL=true
PALMPAY_LEGACY_INTERNAL_WITHDRAWAL=false
# Web / app origin for redirects (defaults to APP_URL if unset)
FRONTEND_URL="${APP_URL}"

# =============================================================================
# Product: Tatum (crypto addresses, webhooks, outbound txs)
# =============================================================================
# 32+ byte secret for AES-256 — encrypts mnemonics / keys in DB (required in prod)
ENCRYPTION_KEY=
TATUM_API_KEY=
TATUM_BASE_URL=https://api.tatum.io/v3
TATUM_BASE_URL_V4=https://api.tatum.io/v4
TATUM_HTTP_TIMEOUT=120
# Override if webhooks must hit a fixed public URL (defaults to {APP_URL}/api/webhooks/tatum)
TATUM_WEBHOOK_URL=
# Local only — mock addresses without Tatum
TATUM_USE_MOCK=false
# Optional fee tuning
TATUM_BTC_FEE_SATVB=12
TATUM_TRON_FEE_LIMIT_SUN=100000000

# =============================================================================
# Product: crypto ledger & master wallet send
# =============================================================================
CRYPTO_MASTER_WALLET_SEND_ENABLED=true
# Chains for artisan crypto:generate-master-wallet --all (comma-separated)
# v1 launch chains (matches wallet_currencies): ETH, BSC, BTC, DOGE, TRON
CRYPTO_MASTER_WALLET_CHAINS=ethereum,bsc,bitcoin,dogecoin,tron
CRYPTO_NGN_PER_USD=1500

# =============================================================================
# Product: CoinMarketCap (scheduled rate sync)
# =============================================================================
COINMARKETCAP_API_KEY=
COINMARKETCAP_BASE_URL=https://pro-api.coinmarketcap.com
COINMARKETCAP_HTTP_TIMEOUT=30

# =============================================================================
# Admin API
# =============================================================================
# Dangerous: replays webhook processing. Keep false in production unless debugging.
ADMIN_WEBHOOK_REPLAY_ENABLED=false

# =============================================================================
# API docs (Swagger) — OTP gate; see routes/web or SwaggerDocsController
# =============================================================================
SWAGGER_DOCS_ALLOWED_EMAILS=hmstech11@gmail.com
SWAGGER_DOCS_SESSION_HOURS=8
SWAGGER_DOCS_OTP_TTL=15

# l5-swagger (optional)
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=
# L5_FORMAT_TO_USE_FOR_DOCS=json

# =============================================================================
# Optional integrations (config/services.php)
# =============================================================================
# RESEND_KEY=
# SLACK_BOT_USER_OAUTH_TOKEN=
# SLACK_BOT_USER_DEFAULT_CHANNEL=
